      "source": [
        "def get_recommendations(title, df, similarity_matrix, top_n=5):\n",
        "    indices = pd.Series(df.index, index=df[\"title\"].str.lower())\n",
        "    indices = indices[~indices.index.duplicated(keep=\"first\")]\n",
        "\n",
        "    title_lower = title.lower()\n",
        "    if title_lower not in indices:\n",
        "        return f\"'{title}' not found in the dataset. Check spelling / try a partial search below.\"\n",
        "\n",
        "    idx = indices[title_lower]\n",
        "    scores = list(enumerate(similarity_matrix[idx]))\n",
        "    scores = sorted(scores, key=lambda x: x[1], reverse=True)[1: top_n + 1]\n",
        "\n",
        "    recommended_indices = [i for i, score in scores]\n",
        "    result = df[[\"title\", \"listed_in\", \"type\"]].iloc[recommended_indices].copy()\n",
        "    result[\"similarity_score\"] = [round(score, 3) for i, score in scores]\n",
        "    return result.reset_index(drop=True)\n",
        "\n",
        "\n",
        "# CHANGE THIS to any title in your dataset\n",
        "sample_title = df[\"title\"].iloc[0]\n",
        "print(f\"Top 5 recommendations for: {sample_title}\\n\")\n",
        "get_recommendations(sample_title, df, similarity_matrix, top_n=5)"

              "    const overlaps = recGenres.some(g =&gt; sourceGenres.has(g));\n",
              "    if (overlaps) overlapCount++;\n",
              "    simSum += sim;\n",
              "    return `\n",
              "      &lt;div class=&quot;stub-card&quot;&gt;\n",

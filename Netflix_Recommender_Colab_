        "import pandas as pd\n",
        "\n",
        "\n",
        "def load_and_prepare_data(csv_path):\n",
        "    # The Kaggle export is UTF-8 but sometimes has a stray invalid byte,\n",
        "    # which breaks strict utf-8 reading. encoding_errors=\"replace\" avoids\n",
        "    # a crash and keeps accented characters readable.\n",
        "    try:\n",
        "        df = pd.read_csv(csv_path, encoding=\"utf-8\", encoding_errors=\"replace\")\n",
        "    except TypeError:\n",
        "        df = pd.read_csv(csv_path, encoding=\"latin-1\")\n",
        "\n",
        "    # Drop empty junk columns some CSV exports create\n",
        "    df = df.loc[:, ~df.columns.str.startswith(\"Unnamed\")]\n",
        "\n",
        "    # Fill missing values in text columns so nothing breaks downstream\n",
        "    text_cols = [\"director\", \"cast\", \"country\", \"listed_in\", \"description\", \"type\"]\n",
        "    for col in text_cols:\n",
        "        if col not in df.columns:\n",
        "            df[col] = \"\"\n",
        "        df[col] = df[col].fillna(\"\")\n",
        "\n",
        "    # Combine attributes into one text \"soup\" per title.\n",
        "    # Genres (listed_in) are repeated to weight them more heavily.\n",
        "    df[\"content_features\"] = (\n",
        "        (df[\"listed_in\"] + \" \") * 2\n",
        "        + df[\"type\"] + \" \"\n",
        "        + df[\"director\"] + \" \"\n",
        "        + df[\"cast\"] + \" \"\n",
        "        + df[\"description\"]\n",
        "    )\n",
        "    return df\n",
        "\n",
        "\n",
        "df = load_and_prepare_data(csv_filename)\n",
        "print(f\"Loaded {len(df)} titles.\")\n",
        "df.head()"

              "\n",
              "/* ================= STATE ================= */\n",
              "let rows = [];          // parsed dataset rows\n",
              "let docs = [];          // { tf: Map(term-&gt;weight), norm, terms: [...] }\n",
              "let idf = new Map();\n",
              "let titleIndex = new Map(); // lower title -&gt; row index\n",
              "\n",
              "const STOPWORDS = new Set((&quot;a an the and or but if then of to in on for with as by at is are was were be been being this that these those his her their its it he she they we you your our from into over under after before during not no nor so than too very can will just also more most other&quot;.split(&quot; &quot;)));\n",
              "\n",
              "/* Self-contained CSV parser (handles quoted fields with commas/newlines, &quot;&quot; escaped quotes) */\n",
              "function parseCSV(text){\n",
              "  const rows = [];\n",
              "  let row = [], field = &#x27;&#x27;, inQuotes = false;\n",
              "  for (let i=0; i&lt;text.length; i++){\n",
              "    const c = text[i];\n",
              "    if (inQuotes){\n",
              "      if (c === &#x27;&quot;&#x27;){\n",
              "        if (text[i+1] === &#x27;&quot;&#x27;){ field += &#x27;&quot;&#x27;; i++; }\n",
              "        else { inQuotes = false; }\n",
              "      } else {\n",
              "        field += c;\n",
              "      }\n",
              "    } else {\n",
              "      if (c === &#x27;&quot;&#x27;){ inQuotes = true; }\n",
              "      else if (c === &#x27;,&#x27;){ row.push(field); field = &#x27;&#x27;; }\n",
              "      else if (c === &#x27;\\n&#x27; || c === &#x27;\\r&#x27;){\n",
              "        if (c === &#x27;\\r&#x27; &amp;&amp; text[i+1] === &#x27;\\n&#x27;) i++;\n",
              "        row.push(field); field = &#x27;&#x27;;\n",
              "        rows.push(row); row = [];\n",
              "      } else {\n",
              "        field += c;\n",
              "      }\n",
              "    }\n",
              "  }\n",
              "  if (field.length || row.length){ row.push(field); rows.push(row); }\n",
              "\n",
              "  const nonEmptyRows = rows.filter(r =&gt; r.length &gt; 1 || (r[0] &amp;&amp; r[0].trim()));\n",
              "  if (!nonEmptyRows.length) return [];\n",
              "\n",
              "  const headers = nonEmptyRows[0].map(h =&gt; h.trim());\n",
              "  return nonEmptyRows.slice(1).map(r =&gt; {\n",
              "    const obj = {};\n",
              "    headers.forEach((h, idx) =&gt; { obj[h] = r[idx] !== undefined ? r[idx] : &#x27;&#x27;; });\n",
              "    return obj;\n",
              "  });\n",
              "}\n",
              "\n",
              "/* ================= CSV LOADING ================= */\n",
              "function parseAndIndex(csvText){\n",
              "  rows = parseCSV(csvText).filter(r =&gt; r.title &amp;&amp; r.title.trim().length);\n",
              "  buildIndex();\n",
              "  document.getElementById(&#x27;datasetStatus&#x27;).textContent = `${rows.length.toLocaleString()} titles loaded`;\n",
              "}\n",
              "\n",
              "function buildIndex(){\n",
              "  titleIndex.clear();\n",
              "  const df = new Map();\n",
              "\n",
              "  const tokenized = rows.map((r, i) =&gt; {\n",
              "    const genres = (r.listed_in || &quot;&quot;);\n",
              "    const combined = [\n",
              "      genres, genres, // weight genres x2\n",
              "      r.type || &quot;&quot;,\n",
              "      r.director || &quot;&quot;,\n",
              "      r.cast || &quot;&quot;,\n",
              "      r.description || &quot;&quot;\n",
              "    ].join(&quot; &quot;).toLowerCase();\n",
              "\n",
              "    const tokens = combined\n",
              "      .replace(/[^a-z0-9\\s]/g, &quot; &quot;)\n",
              "      .split(/\\s+/)\n",
              "      .filter(t =&gt; t.length &gt; 2 &amp;&amp; !STOPWORDS.has(t));\n",
              "\n",
              "    const tf = new Map();\n",
              "    tokens.forEach(t =&gt; tf.set(t, (tf.get(t)||0) + 1));\n",
              "    tf.forEach((_, term) =&gt; df.set(term, (df.get(term)||0) + 1));\n",
              "\n",
              "    const lowerTitle = (r.title||&quot;&quot;).toLowerCase().trim();\n",
              "    if (!titleIndex.has(lowerTitle)) titleIndex.set(lowerTitle, i);\n",
              "\n",
              "    return tf;\n",
              "  });\n",
              "\n",
              "  const N = rows.length;\n",
              "  idf.clear();\n",
              "  df.forEach((count, term) =&gt; idf.set(term, Math.log(N / (1+count)) + 1));\n",
              "\n",
              "  docs = tokenized.map(tf =&gt; {\n",
              "    const weighted = new Map();\n",
              "    let normSq = 0;\n",
              "    tf.forEach((count, term) =&gt; {\n",
              "      const w = count * (idf.get(term)||0);\n",
              "      weighted.set(term, w);\n",
              "      normSq += w*w;\n",
              "    });\n",
              "    return { tf: weighted, norm: Math.sqrt(normSq) || 1 };\n",
              "  });\n",
              "}\n",
              "\n",
              "/* Cosine similarity between selected doc index and every other doc */\n",
              "function recommend(selIdx, topN=5){\n",
              "  const selDoc = docs[selIdx];\n",
              "  const scores = [];\n",
              "  for (let j=0; j&lt;docs.length; j++){\n",
              "    if (j === selIdx) continue;\n",
              "    const other = docs[j];\n",
              "    let dot = 0;\n",
              "    // iterate over the smaller term map for speed\n",
              "    const [small, large] = selDoc.tf.size &lt; other.tf.size ? [selDoc.tf, other.tf] : [other.tf, selDoc.tf];\n",
              "    small.forEach((w, term) =&gt; {\n",
              "      if (large.has(term)) dot += w * large.get(term);\n",
              "    });\n",
              "    const sim = dot / (selDoc.norm * other.norm);\n",
              "    scores.push([j, sim]);\n",
              "  }\n",
              "  scores.sort((a,b)=&gt; b[1]-a[1]);\n",
              "  return scores.slice(0, topN);\n",
              "}\n",
              "\n",
              "/* ================= UI WIRING ================= */\n",
              "const searchInput = document.getElementById(&#x27;searchInput&#x27;);\n",
              "const suggestionsBox = document.getElementById(&#x27;suggestions&#x27;);\n",
              "const emptyState = document.getElementById(&#x27;emptyState&#x27;);\n",
              "const nowPlaying = document.getElementById(&#x27;nowPlaying&#x27;);\n",
              "\n",
              "searchInput.addEventListener(&#x27;input&#x27;, () =&gt; {\n",
              "  const q = searchInput.value.trim().toLowerCase();\n",
              "  if (!q){ suggestionsBox.classList.remove(&#x27;open&#x27;); return; }\n",
              "  const matches = rows\n",

        "s23,Movie,Klaus,Sergio Pablos,\"Jason Schwartzman, J.K. Simmons\",Spain,2019,PG,98 min,\"Children & Family Movies, Comedies\",\"A postman in a frozen town discovers a secret feud has kept the town joyless for years, and enlists a reclusive toymaker to bring back holiday cheer.\"\n",
        "s24,TV Show,Kingdom,Kim Seong-hun,\"Ju Ji-hoon, Bae Doona\",South Korea,2020,TV-MA,2 Seasons,\"International TV Shows, Horror Movies, Crime TV Shows\",\"A crown prince fights a mysterious plague that turns people into zombies while a bigger threat looms in the shadows of his ambitious uncle.\"\n",
        "s25,Movie,Roma,Alfonso Cuaron,\"Yalitza Aparicio, Marina de Tavira\",Mexico,2018,R,135 min,\"Dramas, International Movies\",\"In 1970s Mexico City, a housekeeper for a family undergoing a tumultuous period faces her own devastating loss amid the political turbulence.\"`;\n",
        "\n",
        "/* ================= STATE ================= */\n",
        "let rows = [];          // parsed dataset rows\n",
        "let docs = [];          // { tf: Map(term->weight), norm, terms: [...] }\n",
        "let idf = new Map();\n",
        "let titleIndex = new Map(); // lower title -> row index\n",
        "\n",
        "const STOPWORDS = new Set((\"a an the and or but if then of to in on for with as by at is are was were be been being this that these those his her their its it he she they we you your our from into over under after before during not no nor so than too very can will just also more most other\".split(\" \")));\n",
        "\n",
        "/* Self-contained CSV parser (handles quoted fields with commas/newlines, \"\" escaped quotes) */\n",
        "function parseCSV(text){\n",
        "  const rows = [];\n",
        "  let row = [], field = '', inQuotes = false;\n",
        "  for (let i=0; i<text.length; i++){\n",
        "    const c = text[i];\n",
        "    if (inQuotes){\n",
        "      if (c === '\"'){\n",
        "        if (text[i+1] === '\"'){ field += '\"'; i++; }\n",
        "        else { inQuotes = false; }\n",
        "      } else {\n",
        "        field += c;\n",
        "      }\n",
        "    } else {\n",
        "      if (c === '\"'){ inQuotes = true; }\n",
        "      else if (c === ','){ row.push(field); field = ''; }\n",
        "      else if (c === '\\n' || c === '\\r'){\n",
        "        if (c === '\\r' && text[i+1] === '\\n') i++;\n",
        "        row.push(field); field = '';\n",
        "        rows.push(row); row = [];\n",
        "      } else {\n",
        "        field += c;\n",
        "      }\n",
        "    }\n",
        "  }\n",
        "  if (field.length || row.length){ row.push(field); rows.push(row); }\n",
        "\n",
        "  const nonEmptyRows = rows.filter(r => r.length > 1 || (r[0] && r[0].trim()));\n",
        "  if (!nonEmptyRows.length) return [];\n",
        "\n",
        "  const headers = nonEmptyRows[0].map(h => h.trim());\n",
        "  return nonEmptyRows.slice(1).map(r => {\n",
        "    const obj = {};\n",
        "    headers.forEach((h, idx) => { obj[h] = r[idx] !== undefined ? r[idx] : ''; });\n",
        "    return obj;\n",
        "  });\n",
        "}\n",
        "\n",
        "/* ================= CSV LOADING ================= */\n",
        "function parseAndIndex(csvText){\n",
        "  rows = parseCSV(csvText).filter(r => r.title && r.title.trim().length);\n",
        "  buildIndex();\n",
        "  document.getElementById('datasetStatus').textContent = `${rows.length.toLocaleString()} titles loaded`;\n",
        "}\n",
        "\n",
        "function buildIndex(){\n",
        "  titleIndex.clear();\n",
        "  const df = new Map();\n",
        "\n",
        "  const tokenized = rows.map((r, i) => {\n",
        "    const genres = (r.listed_in || \"\");\n",
        "    const combined = [\n",
        "      genres, genres, // weight genres x2\n",
        "      r.type || \"\",\n",
        "      r.director || \"\",\n",
        "      r.cast || \"\",\n",
        "      r.description || \"\"\n",
        "    ].join(\" \").toLowerCase();\n",
        "\n",
        "    const tokens = combined\n",
        "      .replace(/[^a-z0-9\\s]/g, \" \")\n",
        "      .split(/\\s+/)\n",
        "      .filter(t => t.length > 2 && !STOPWORDS.has(t));\n",
        "\n",
        "    const tf = new Map();\n",
        "    tokens.forEach(t => tf.set(t, (tf.get(t)||0) + 1));\n",
        "    tf.forEach((_, term) => df.set(term, (df.get(term)||0) + 1));\n",
        "\n",
        "    const lowerTitle = (r.title||\"\").toLowerCase().trim();\n",
        "    if (!titleIndex.has(lowerTitle)) titleIndex.set(lowerTitle, i);\n",
        "\n",
        "    return tf;\n",
        "  });\n",
        "\n",
        "  const N = rows.length;\n",
        "  idf.clear();\n",
        "  df.forEach((count, term) => idf.set(term, Math.log(N / (1+count)) + 1));\n",
        "\n",
        "  docs = tokenized.map(tf => {\n",
        "    const weighted = new Map();\n",
        "    let normSq = 0;\n",
        "    tf.forEach((count, term) => {\n",
        "      const w = count * (idf.get(term)||0);\n",
        "      weighted.set(term, w);\n",
        "      normSq += w*w;\n",
        "    });\n",
        "    return { tf: weighted, norm: Math.sqrt(normSq) || 1 };\n",
        "  });\n",
        "}\n",
        "\n",
        "/* Cosine similarity between selected doc index and every other doc */\n",
        "function recommend(selIdx, topN=5){\n",
        "  const selDoc = docs[selIdx];\n",
        "  const scores = [];\n",
        "  for (let j=0; j<docs.length; j++){\n",
        "    if (j === selIdx) continue;\n",
        "    const other = docs[j];\n",
        "    let dot = 0;\n",
        "    // iterate over the smaller term map for speed\n",
        "    const [small, large] = selDoc.tf.size < other.tf.size ? [selDoc.tf, other.tf] : [other.tf, selDoc.tf];\n",
        "    small.forEach((w, term) => {\n",
        "      if (large.has(term)) dot += w * large.get(term);\n",
        "    });\n",
        "    const sim = dot / (selDoc.norm * other.norm);\n",
        "    scores.push([j, sim]);\n",
        "  }\n",
        "  scores.sort((a,b)=> b[1]-a[1]);\n",
        "  return scores.slice(0, topN);\n",
        "}\n",
        "\n",
        "/* ================= UI WIRING ================= */\n",
        "const searchInput = document.getElementById('searchInput');\n",
        "const suggestionsBox = document.getElementById('suggestions');\n",
        "const emptyState = document.getElementById('emptyState');\n",
        "const nowPlaying = document.getElementById('nowPlaying');\n",
        "\n",
        "searchInput.addEventListener('input', () => {\n",
        "  const q = searchInput.value.trim().toLowerCase();\n",
        "  if (!q){ suggestionsBox.classList.remove('open'); return; }\n",
        "  const matches = rows\n",
        "    .map((r,i)=>({r,i}))\n",
        "    .filter(({r}) => r.title && r.title.toLowerCase().includes(q))\n",
        "    .slice(0, 8);\n",
        "\n",
        "  if (!matches.length){ suggestionsBox.classList.remove('open'); return; }\n",
        "\n",
        "  suggestionsBox.innerHTML = matches.map(({r,i}) => `\n",
        "    <div class=\"suggestion-item\" data-idx=\"${i}\">\n",
        "      <span>${escapeHtml(r.title)}</span>\n",
        "      <span class=\"suggestion-genre\">${escapeHtml((r.listed_in||'').split(',')[0]||'')}</span>\n",
        "    </div>\n",
        "  `).join('');\n",
        "  suggestionsBox.classList.add('open');\n",
        "\n",
        "  suggestionsBox.querySelectorAll('.suggestion-item').forEach(el => {\n",
        "    el.addEventListener('click', () => {\n",
        "      const idx = parseInt(el.dataset.idx, 10);\n",
        "      searchInput.value = rows[idx].title;\n",
        "      suggestionsBox.classList.remove('open');\n",
        "      showRecommendations(idx);\n",
        "    });\n",
        "  });\n",
        "});\n",
        "\n",
        "document.addEventListener('click', (e) => {\n",
        "  if (!e.target.closest('.search-wrap')) suggestionsBox.classList.remove('open');\n",
        "});\n",
        "\n",
        "function escapeHtml(str){\n",
        "  return (str||\"\").replace(/[&<>\"']/g, m => ({'&':'&amp;','<':'&lt;','>':'&gt;','\"':'&quot;',\"'\":'&#39;'}[m]));\n",
        "}\n",
        "\n",
        "function showRecommendations(idx){\n",
        "  const r = rows[idx];\n",
        "  emptyState.style.display = 'none';\n",
        "  nowPlaying.classList.add('show');\n",
        "\n",
        "  document.getElementById('npTitle').textContent = r.title;\n",
        "  document.getElementById('npMeta').textContent = `${r.type || ''} · ${r.release_year || ''} · ${r.country || 'Unknown country'}`;\n",
        "  document.getElementById('npGenres').innerHTML = (r.listed_in||'').split(',').filter(g=>g.trim())\n",
        "    .map(g => `<span class=\"tag\">${escapeHtml(g.trim())}</span>`).join('');\n",
        "\n",
        "  const top = recommend(idx, 5);\n",
        "  const sourceGenres = new Set((r.listed_in||'').split(',').map(g=>g.trim()).filter(Boolean));\n",
        "\n",
        "  let overlapCount = 0;\n",
        "  let simSum = 0;\n",
        "  const grid = document.getElementById('recGrid');\n",
        "  grid.innerHTML = top.map(([j, sim]) => {\n",
        "    const rec = rows[j];\n",
        "    const recGenres = (rec.listed_in||'').split(',').map(g=>g.trim()).filter(Boolean);\n",
        "    const overlaps = recGenres.some(g => sourceGenres.has(g));\n",
        "    if (overlaps) overlapCount++;\n",
        "    simSum += sim;\n",
        "    return `\n",
        "      <div class=\"stub-card\">\n",
        "        <div class=\"stub-score\">\n",
        "          <div class=\"stub-pct\">${Math.round(sim*100)}%</div>\n",
        "          <div class=\"stub-pct-label\">MATCH</div>\n",
        "        </div>\n",
        "        <div class=\"stub-body\">\n",
        "          <p class=\"stub-title\">${escapeHtml(rec.title)}</p>\n",
        "          <span class=\"stub-type\">${escapeHtml(rec.type||'')}</span>\n",
        "          <div class=\"stub-genres\">${escapeHtml(recGenres.slice(0,3).join(' · '))}</div>\n",
        "        </div>\n",
        "      </div>\n",
        "    `;\n",
        "  }).join('');\n",
        "\n",
        "  document.getElementById('evalOverlap').textContent = `${Math.round((overlapCount/top.length)*100)}%`;\n",
        "  document.getElementById('evalAvgSim').textContent = (simSum/top.length).toFixed(3);\n",
        "  document.getElementById('evalCorpus').textContent = rows.length.toLocaleString();\n",
        "}\n",
        "\n",
        "/* ================= FILE UPLOAD ================= */\n",
        "document.getElementById('csvInput').addEventListener('change', (e) => {\n",
        "  const file = e.target.files[0];\n",
        "  if (!file) return;\n",
        "  const reader = new FileReader();\n",
        "  reader.onload = (ev) => {\n",
        "    parseAndIndex(ev.target.result);\n",
        "    document.getElementById('datasetStatus').textContent = `${file.name} — ${rows.length.toLocaleString()} titles loaded`;\n",
        "    searchInput.value = '';\n",
        "    nowPlaying.classList.remove('show');\n",
        "    emptyState.style.display = 'block';\n",
        "  };\n",
        "  reader.readAsText(file, 'utf-8');\n",
        "});\n",
        "\n",
        "/* ================= INIT ================= */\n",
        "parseAndIndex(DEMO_CSV);\n",
        "</script>\n",
        "</body>\n",
        "</html>\n",
        "'''\n"

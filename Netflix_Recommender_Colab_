      "source": [
        "def evaluate_recommendations(title, df, similarity_matrix, top_n=5):\n",
        "    indices = pd.Series(df.index, index=df[\"title\"].str.lower())\n",
        "    indices = indices[~indices.index.duplicated(keep=\"first\")]\n",
        "    idx = indices[title.lower()]\n",
        "    source_genres = set(g.strip() for g in df.iloc[idx][\"listed_in\"].split(\",\"))\n",
        "\n",
        "    recs = get_recommendations(title, df, similarity_matrix, top_n)\n",
        "    if isinstance(recs, str):\n",
        "        return recs\n",
        "\n",
        "    overlap_count = 0\n",
        "    for genres in recs[\"listed_in\"]:\n",
        "        rec_genres = set(g.strip() for g in genres.split(\",\"))\n",
        "        if source_genres & rec_genres:\n",
        "            overlap_count += 1\n",
        "\n",
        "    genre_overlap_score = overlap_count / len(recs)\n",
        "    avg_similarity = recs[\"similarity_score\"].mean()\n",
        "\n",
        "    return {\n",
        "        \"title\": title,\n",
        "        \"genre_overlap_score\": round(genre_overlap_score, 2),\n",
        "        \"average_similarity_score\": round(avg_similarity, 3),\n",
        "    }\n",
        "\n",
        "\n",
        "evaluate_recommendations(sample_title, df, similarity_matrix, top_n=5)"
      ],
